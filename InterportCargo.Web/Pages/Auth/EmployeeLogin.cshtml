@page
@model InterportCargo.Web.Pages.Auth.EmployeeLoginModel
@{
    ViewData["Title"] = "Employee Login";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h2 class="mb-4">Employee Login</h2>
        <p class="text-muted">Quotation Officers only. Use your work email and system-issued key.</p>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label"></label>
                <input asp-for="Input.Email" class="form-control" type="email" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.EmployeeKey" class="form-label"></label>
                <input asp-for="Input.EmployeeKey" class="form-control" type="password" />
                <span asp-validation-for="Input.EmployeeKey" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-secondary w-100">Log In</button>
        </form>

        <p class="mt-3 text-center">
            <a asp-page="/Index">Back to home</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
