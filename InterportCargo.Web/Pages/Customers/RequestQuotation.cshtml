@page
@model InterportCargo.Web.Pages.Customers.RequestQuotationModel
@{
    ViewData["Title"] = "Request a Quotation";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <h2 class="mb-4">Request a Quotation</h2>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <h5 class="mt-3">Shipment Details</h5>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Input.Source" class="form-label"></label>
                    <input asp-for="Input.Source" class="form-control" placeholder="Country of origin" />
                    <span asp-validation-for="Input.Source" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.Destination" class="form-label"></label>
                    <input asp-for="Input.Destination" class="form-control" />
                    <span asp-validation-for="Input.Destination" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Input.NumberOfContainers" class="form-label"></label>
                    <input asp-for="Input.NumberOfContainers" class="form-control" type="number" min="1" />
                    <span asp-validation-for="Input.NumberOfContainers" class="text-danger"></span>
                </div>
            </div>

            <h5 class="mt-4">Nature of Package</h5>
            <div class="row g-3">
                <div class="col-md-12">
                    <label asp-for="Input.GoodsType" class="form-label"></label>
                    <input asp-for="Input.GoodsType" class="form-control" placeholder="e.g. Electronics, Perishables, Machinery" />
                    <span asp-validation-for="Input.GoodsType" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.PackageWidth" class="form-label"></label>
                    <input asp-for="Input.PackageWidth" class="form-control" type="number" step="0.01" min="0.01" />
                    <span asp-validation-for="Input.PackageWidth" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.PackageHeight" class="form-label"></label>
                    <input asp-for="Input.PackageHeight" class="form-control" type="number" step="0.01" min="0.01" />
                    <span asp-validation-for="Input.PackageHeight" class="text-danger"></span>
                </div>
            </div>

            <h5 class="mt-4">Nature of Job</h5>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Input.JobNature" class="form-label"></label>
                    <select asp-for="Input.JobNature" asp-items="Html.GetEnumSelectList<InterportCargo.Web.Models.JobNature>()" class="form-select">
                        <option value="">-- Select --</option>
                    </select>
                    <span asp-validation-for="Input.JobNature" class="text-danger"></span>
                </div>
                <div class="col-md-6 d-flex align-items-center">
                    <div class="form-check mt-3">
                        <input asp-for="Input.RequiresPacking" class="form-check-input" type="checkbox" />
                        <label asp-for="Input.RequiresPacking" class="form-check-label"></label>
                    </div>
                </div>
            </div>

            <h5 class="mt-4">Quarantine Details</h5>
            <div class="row g-3">
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="Input.RequiresQuarantine" class="form-check-input" type="checkbox" id="quarantineCheck" />
                        <label asp-for="Input.RequiresQuarantine" class="form-check-label"></label>
                    </div>
                </div>
                <div id="quarantineDetails" class="col-12 row g-3" style="display:none">
                    <div class="col-md-6">
                        <label asp-for="Input.QuarantineOrigin" class="form-label"></label>
                        <input asp-for="Input.QuarantineOrigin" class="form-control" />
                        <span asp-validation-for="Input.QuarantineOrigin" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Input.QuarantineTreatmentHistory" class="form-label"></label>
                        <input asp-for="Input.QuarantineTreatmentHistory" class="form-control" placeholder="e.g. Previously fumigated, heat treated" />
                        <span asp-validation-for="Input.QuarantineTreatmentHistory" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <h5 class="mt-4">Fumigation Details</h5>
            <div class="row g-3">
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="Input.RequiresFumigation" class="form-check-input" type="checkbox" id="fumigationCheck" />
                        <label asp-for="Input.RequiresFumigation" class="form-check-label"></label>
                    </div>
                </div>
                <div id="fumigationDetails" class="col-md-12" style="display:none">
                    <label asp-for="Input.FumigationPestThreats" class="form-label"></label>
                    <input asp-for="Input.FumigationPestThreats" class="form-control" placeholder="e.g. Red imported fire ants, Asian gypsy moth" />
                    <span asp-validation-for="Input.FumigationPestThreats" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Submit Request</button>
                <a asp-page="/Customers/Dashboard" class="btn btn-outline-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Show/hide quarantine detail fields
        const quarantineCheck = document.getElementById('quarantineCheck');
        const quarantineDetails = document.getElementById('quarantineDetails');
        quarantineCheck.addEventListener('change', () => {
            quarantineDetails.style.display = quarantineCheck.checked ? 'flex' : 'none';
        });
        if (quarantineCheck.checked) quarantineDetails.style.display = 'flex';

        // Show/hide fumigation detail fields
        const fumigationCheck = document.getElementById('fumigationCheck');
        const fumigationDetails = document.getElementById('fumigationDetails');
        fumigationCheck.addEventListener('change', () => {
            fumigationDetails.style.display = fumigationCheck.checked ? 'block' : 'none';
        });
        if (fumigationCheck.checked) fumigationDetails.style.display = 'block';
    </script>
}
